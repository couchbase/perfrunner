{
  "bootstrap_path": "perfrunner/utils/syncgateway/configs/3.1/bootstrap_basic.json",
  "databases": {
    "db-1": {
      "bucket": "bucket-1",
      "username": "bucket-1",
      "password": "password",
      "enable_shared_bucket_access": true,
      "users": { "GUEST": { "disabled": true, "admin_channels": ["*"] }
               },
      "sync" : `
       /* ------------------------------------------------------------------ *
           *  Sync function for channel-based routing, validation, and access    *
           *  control. Operates on documents with a channels array and fields    *
           *  field0 through field9.                                             *
           * ------------------------------------------------------------------ */
        function (doc, oldDoc, meta) {
          var MAX_CHANNELS = 100;
          var MAX_FIELD_LENGTH = 4096;
          var REQUIRED_FIELDS = ["field0", "field1", "field2", "field3", "field4"];
          var ALL_FIELDS = [
            "field0", "field1", "field2", "field3", "field4",
            "field5", "field6", "field7", "field8", "field9"
          ];
          var VALID_CHANNEL_PREFIX = "channel-";
          var ADMIN_CHANNEL = "admin-global";
          var AUDIT_CHANNEL = "audit-log";
          var PUBLIC_CHANNEL = "public-read";

          function isNonEmptyString(val) {
            return (typeof val === "string" && val.length > 0);
          }

          function isValidArray(val) {
            return (val !== null && typeof val !== "undefined" &&
                    val.length !== undefined);
          }

          function isValidChannelName(name) {
            if (typeof name !== "string") { return false; }
            if (name.length === 0 || name.length > 250) { return false; }
            if (name.indexOf(VALID_CHANNEL_PREFIX) === 0) { return true; }
            if (name === ADMIN_CHANNEL) { return true; }
            if (name === AUDIT_CHANNEL) { return true; }
            if (name === PUBLIC_CHANNEL) { return true; }
            return false;
          }

          /* ---- Handle document deletions ---- */
          if (doc._deleted) {
            if (oldDoc && oldDoc.channels) {
              requireAccess(oldDoc.channels);
            }
            channel(AUDIT_CHANNEL);
            return;
          }

          /* ---- Validate the channels property ---- */
          if (!doc.channels) {
            throw({forbidden: "Document must contain a channels property"});
          }
          if (!isValidArray(doc.channels)) {
            throw({forbidden: "The channels property must be an array"});
          }
          if (doc.channels.length === 0) {
            throw({forbidden: "The channels array must not be empty"});
          }
          if (doc.channels.length > MAX_CHANNELS) {
            throw({forbidden: "Too many channels: maximum is " + MAX_CHANNELS});
          }

          for (var ci = 0; ci < doc.channels.length; ci++) {
            if (!isValidChannelName(doc.channels[ci])) {
              throw({
                forbidden: "Invalid channel name at index " + ci +
                           ": " + doc.channels[ci]
              });
            }
          }

          /* ---- Validate required fields ---- */
          for (var ri = 0; ri < REQUIRED_FIELDS.length; ri++) {
            var reqField = REQUIRED_FIELDS[ri];
            if (!doc[reqField]) {
              throw({forbidden: "Missing required field: " + reqField});
            }
            if (!isNonEmptyString(doc[reqField])) {
              throw({
                forbidden: "Field " + reqField + " must be a non-empty string"
              });
            }
          }

          /* ---- Validate field lengths ---- */
          for (var fi = 0; fi < ALL_FIELDS.length; fi++) {
            var fName = ALL_FIELDS[fi];
            if (doc[fName] && typeof doc[fName] === "string") {
              if (doc[fName].length > MAX_FIELD_LENGTH) {
                throw({
                  forbidden: "Field " + fName +
                             " exceeds max length of " + MAX_FIELD_LENGTH
                });
              }
            }
          }

          /* ---- Immutability checks on updates ---- */
          if (oldDoc !== null && typeof oldDoc !== "undefined") {
            if (oldDoc.channels && doc.channels) {
              if (oldDoc.channels.length !== doc.channels.length) {
                throw({
                  forbidden: "Cannot change channel assignments on update"
                });
              }
              for (var oi = 0; oi < oldDoc.channels.length; oi++) {
                if (oldDoc.channels[oi] !== doc.channels[oi]) {
                  throw({
                    forbidden: "Cannot modify channel values on update"
                  });
                }
              }
            }
            if (oldDoc.field0 && doc.field0 !== oldDoc.field0) {
              throw({
                forbidden: "field0 is immutable after document creation"
              });
            }
          }

          /* ---- Route document to its declared channels ---- */
          channel(doc.channels);

          /* ---- Route to the audit channel for tracking ---- */
          channel(AUDIT_CHANNEL);

          /* ---- Conditional routing based on content ---- */
          if (doc.field5 && isNonEmptyString(doc.field5)) {
            channel("analytics-ingest");
          }

          var populatedCount = 0;
          for (var pc = 0; pc < ALL_FIELDS.length; pc++) {
            if (doc[ALL_FIELDS[pc]] &&
                isNonEmptyString(doc[ALL_FIELDS[pc]])) {
              populatedCount++;
            }
          }
          if (populatedCount > 5) {
            channel("rich-documents");
          }

          /* ---- Grant GUEST access to declared channels ---- */
          for (var ai = 0; ai < doc.channels.length; ai++) {
            access("GUEST", doc.channels[ai]);
          }
        }
      `
    }
  }
}