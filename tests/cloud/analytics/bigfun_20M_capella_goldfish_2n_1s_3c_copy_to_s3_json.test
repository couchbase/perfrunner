[test_case]
test = perfrunner.tests.analytics.ColumnarCopyToObjectStoreTest

[showfast]
title = 2 nodes, BigFUN 20M users (320M docs), s=1 c=3, Capella Columnar, COPY TO S3, json
component = analyticscloud
category = latency
sub_category = {provider}

[stats]
server_processes = java

[cluster]
initial_nodes = 2
enable_n2n_encryption = all

[backup]
obj_staging_dir = /stage
obj_region = us-east-1
aws_credential_path = /root/.ssh

[analytics]
dataset_conf_file = tests/analytics/config/bigfun_3_to_3_datasets_external.yaml
aws_credential_path = /root/.ssh/

[analytics_external_data]
link_type = s3
region = us-east-1
obj_store_name = analytics-bigfun20m-json
file_format = json
file_include = *.json

[columnar_copy_to]
object_store_file_formats = json
max_objects_per_files = 1000, 10000, 100000, 1000000
object_store_compressions = none
object_store_query_file = tests/cloud/analytics/workload/bigfun_copy_to_blob_store_queries.yaml
