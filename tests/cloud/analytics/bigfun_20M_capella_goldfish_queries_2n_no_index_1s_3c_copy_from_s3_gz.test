[test_case]
test = perfrunner.tests.analytics.ColumnarCopyFromObjectStoreTest

[showfast]
title = 2 nodes, BigFUN 20M users (320M docs), no indexes (ad hoc), s=1 c=3, Capella Columnar, COPY FROM S3, gz
component = analyticscloud
category = latency
sub_category = {provider}

[stats]
server_processes = cbas java

[cluster]
initial_nodes = 2
enable_n2n_encryption = all

[backup]
obj_staging_dir = /stage
obj_region = us-east-1
aws_credential_path = /root/.ssh

[analytics]
queries = perfrunner/workloads/bigfun/queries_without_index_external.yaml
dataset_conf_file = tests/analytics/config/bigfun_3_to_3_datasets_external.yaml
aws_credential_path = /root/.ssh/

[analytics_external_data]
link_type = s3
region = us-east-1
obj_store_name = analytics-bigfun20m-gz
file_format = json
file_include = *.gz

[access]
ops = 5
workers = 1

[clients]
python_client = 4.0.2
