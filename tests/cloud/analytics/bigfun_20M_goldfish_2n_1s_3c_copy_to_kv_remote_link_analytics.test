[test_case]
test = perfrunner.tests.analytics.ColumnarCopyToKVRemoteLinkTest
use_workers = 0

[showfast]
title = 2 nodes, BigFUN 20M users (320M docs), s=1 c=3, Simulated Columnar, COPY TO KV
component = analyticscloud
category = latency
sub_category = {provider}

[stats]
server_processes = java

[cluster]
mem_quota = 256
analytics_mem_quota = 51200
initial_nodes = 4 2
num_buckets = 1

[backup]
obj_staging_dir = /stage
obj_region = us-east-1
aws_credential_path = /root/.ssh

[analytics]
dataset_conf_file = tests/analytics/config/bigfun_3_to_3_datasets_external.yaml
couchbase_link_name = RemoteLink
aws_credential_path = /root/.ssh/

[analytics_external_data]
link_type = s3
region = us-east-1
obj_store_name = analytics-bigfun20m-json
file_format = json
file_include = *.json

[columnar_copy_to]
kv_query_file = tests/cloud/analytics/workload/bigfun_copy_to_kv_queries.yaml

[clients]
python_client = 4.2.0
