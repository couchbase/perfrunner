[test_case]
test = perfrunner.tests.analytics.CH2ColumnarStandaloneDatasetTest

[showfast]
title = CH2 5000W, 4A, c=11 (standalone collections), analytics-only workload, No CBO, Hand-Optimized Queries
component = analyticscloud
category = ch2
sub_category = {provider}

[stats]
server_processes = java

[cluster]
mem_quota = 100
analytics_mem_quota = 25600
initial_nodes = 4
num_buckets = 1
bucket_name = bench

[analytics_external_data]
link_type = gcs
obj_store_name = analytics-ch2-5000w-gz
file_format = json
file_include = gz

[ch2]
warehouses = 5000
aclients = 1
tclients = 0
load_tclients = 48
iterations = 2
warmup_iterations = 1
duration = 0
warmup_duration = 0
workload = ch2_analytics
datagen_seed = 12345
use_backup = false
create_gsi_index = false
