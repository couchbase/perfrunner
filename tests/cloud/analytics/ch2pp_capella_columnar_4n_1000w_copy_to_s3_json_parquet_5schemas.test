[test_case]
test = perfrunner.tests.analytics.CH2CapellaColumnarCopyToObjectStoreTest

[showfast]
title = Copy To S3, CH2++0 1000W, 4A, c=11 (standalone collections), 5 Heterogeneous Schemas
component = analyticscloud
category = latency
sub_category = {provider}

[stats]
server_processes = java

[cluster]
initial_nodes = 4
enable_n2n_encryption = all

[analytics]
aws_credential_path = /root/.ssh/

[analytics_external_data]
link_type = s3
region = us-east-1
obj_store_name = analytics-ch2pp0-1000w-heterogeneous-schemas-gz
file_format = json
file_include = *.gz

[ch2]
schema = ch2pp

[columnar]
object_store_import_datasets = customer_5schemas_no_empty_arrays:customer, stock_5schemas:stock, orders_5schemas:orders

[columnar_copy_to]
object_store_file_formats = json, parquet
max_objects_per_files = 10000
object_store_compressions = none
object_store_query_file = tests/cloud/analytics/workload/ch2pp_copy_to_blob_store_parquet_queries.yaml
parquet_schema_inference = true
parquet_max_schemas = 5
