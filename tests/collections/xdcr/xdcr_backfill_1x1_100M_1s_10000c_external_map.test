[test_case]
test = perfrunner.tests.xdcr.XdcrCollectionMapTest

[showfast]
title = Avg. XDCR rate (items/sec), 1 -> 1 (2 source nozzles, 4 target nozzles), 1 bucket x 100M x 1KB, s=1, c=10000, external_map
component = xdcr
category = init_single
orderby = aa

[stats]
server_processes = goxdcr

[cluster]
mem_quota = 204800
initial_nodes = 1 1
num_buckets = 1

[collection]
scopes_per_bucket = 1
collections_per_scope = 10000

[bucket]
replica_number = 0

[xdcr_cluster]
sourceNozzlePerNode = 2
targetNozzlePerNode = 4

[load]
items = 100000000
size = 1024
workers = 80
doc_gen = large

[xdcr]
