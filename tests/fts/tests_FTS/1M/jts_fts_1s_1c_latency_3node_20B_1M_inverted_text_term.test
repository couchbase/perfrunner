[test_case]
test = perfrunner.tests.fts.FTSLatencyLoadTest

[showfast]
title = InvertedText Term Query, wiki 1M x 1KB, 3 node, FTS, s=1 c=1, Case2 Baseline
component = jts
category = 1M
sub_category = Latency
orderby = q0b00000014

[cluster]
mem_quota = 51024
initial_nodes = 3
num_buckets = 1
fts_index_mem_quota = 20000

[collection]
config = collections/1bucket_1scope_1collection_basic.json

[load]
items = 1000000
size = 1024
workers = 10
doc_gen = fts_doc

[jts]
jts_repo_branch = multi_query_support
logging_method = bucket_wise
jts_instances = 1
test_duration = 600
test_total_docs = 1000000
test_query_workers = 1
test_kv_workers = 0
test_kv_throughput_goal = 0
test_driver = couchbase
test_stats_limit = 1000000
test_stats_aggregation_step = 100
test_debug = false
test_query_limit = 1000
test_worker_type = validatedLatency
couchbase_index_name = perf_fts_index
test_data_file = ../tests/fts/data/benchmark/med.txt
test_query_type = term
test_query_field = text
couchbase_index_configfile = tests/fts/index/fts_tvectors_off_latency.json
report_percentiles = 80,95,99

[profiling]
services = fts
