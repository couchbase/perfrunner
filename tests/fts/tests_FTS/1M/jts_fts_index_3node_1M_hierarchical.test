[test_case]
test = perfrunner.tests.fts.FTSIndexLoadTest

[showfast]
title = Hierarchical Index Build (sec), 1M docs, 3 node, FTS
component = jts
category = 1M
sub_category = IndexBuild
orderby = q0b00000010

[cluster]
mem_quota = 51024
initial_nodes = 3
num_buckets = 1
fts_index_mem_quota = 20000

[load]
items = 1000000
workers = 10
doc_gen = hierarchical_fts_doc
fts_data_spread_workers = 100

[collection]
config = collections/1bucket_1scope_1collection_basic.json

[jts]
jts_instances = 1
logging_method = bucket_wise
test_mutation_field = company.name
jts_repo_branch = multi_query_support
test_duration = 0
test_total_docs = 1000000
test_driver = couchbase
test_stats_limit = 1000000
test_stats_aggregation_step = 100
test_debug = false
couchbase_index_name = perf_fts_index
couchbase_index_configfile = tests/fts/index/fts_hierarchical.json
