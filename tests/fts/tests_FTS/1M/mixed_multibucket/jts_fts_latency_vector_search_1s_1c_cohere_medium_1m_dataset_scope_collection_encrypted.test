[test_case]
test = perfrunner.tests.fts.FTSLatencyTest

[showfast]
title = Vector Search COHERE 1M x 768dim, Pure KNN, L2 Norm, scope.collection, 3 Node, 1s 1c, Native Encryption
component = jts
category = vector
sub_category = Latency
orderby = q0b10000010

[cluster]
mem_quota = 51024
initial_nodes = 3
num_buckets = 1
fts_index_mem_quota = 20000

[bucket]
encryption_at_rest = true

[load]
items = 1000000
fts_data_spread_workers = 100

[collection]
config = collections/1bucket_1scope_1collection_basic.json

[jts]
jts_repo_branch = multi_query_support
logging_method = bucket_wise
jts_instances = 1
test_duration = 600
test_total_docs = 1000000
test_query_workers = 1
test_kv_workers = 0
test_kv_throughput_goal = 0
test_driver = couchbase
test_stats_limit = 1000000
test_stats_aggregation_step = 100
test_debug = false
test_query_limit = 1000
test_worker_type = validatedLatency
couchbase_index_name = perf_fts_index
test_data_file = ../tests/fts/data/vector/testData/cohere_1M_100Numeric_1100To1500TextHits.txt
test_query_type = vector
test_query_field = emb
couchbase_index_configfile = tests/fts/index/fts_vector_l2_norm_scope_collection.json
raw_query_map_file = tests/fts/data/vector/raw_vector_match_none_query.json
report_percentiles = 80,95,99
vector_dimension = 768

[restore]
backup_storage = /data2
backup_repo = fts_cohere_medium_1m_768_dims

[profiling]
services = fts
