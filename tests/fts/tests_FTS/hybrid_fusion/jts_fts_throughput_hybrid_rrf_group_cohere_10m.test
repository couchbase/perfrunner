[test_case]
test = perfrunner.tests.fts.FTSFusionMultiVariantThroughputTest

[showfast]
title = COHERE dataset, wiki 10M x 768 dim, 3 node, 1 bucket, 1s, 1c, FTS
component = jts
category = hybrid_fusion
sub_category = Throughput
orderby = q0b00000110

[cluster]
mem_quota = 51024
initial_nodes = 3
num_buckets = 1
fts_index_mem_quota = 20000

[load]
items = 10000000
fts_data_spread_workers = 100
key_fmtr = no_hash

[access]
items = 10000000
workers = 100
modify_doc_loader = text_vector

[collection]
config = collections/1bucket_1scope_1collection_basic.json

[jts]
jts_repo_branch = multi_query_support
logging_method = bucket_wise
jts_instances = 6
test_query_workers = 15
test_kv_workers = 5
test_kv_throughput_goal = 1660
test_duration = 600
test_total_docs = 10000000
test_driver = couchbase
test_stats_limit = 10000000
test_stats_aggregation_step = 100
test_debug = false
test_query_limit = 20
test_worker_type = validatedThroughput
couchbase_index_name = perf_fts_index
test_data_file = ../tests/fts/data/vector/testData/cohere_10M_100Numeric_9935To11500TextHits.txt
test_query_type = fusion
test_query_field = emb
test_query_field2 = text
couchbase_index_configfile = tests/fts/index/fts_vector_l2_norm_text_vector_index.json
vector_dimension = 768
search_query_timeout_in_sec = 100
fusion_variants_file = tests/fts/tests_FTS/hybrid_fusion/variants/rrf_throughput.yaml

[restore]
backup_storage = /data2
backup_repo = fts_cohere_large_10m_768_dims
