[test_case]
test = perfrunner.tests.secondary.ConcurrentDropKeySecondaryIndexTest

[showfast]
title = DropKey, 1 bucket x 18M x 1KB, 100 indexes (~4GB lss_data_size each, 500B keys), Plasma, Native Encryption
component = secondary
category = dropkey
sub_category = Plasma

[stats]
server_processes = projector

[cluster]
mem_quota = 50000
index_mem_quota = 20000
initial_nodes = 6
num_buckets = 1

[compaction]
db_percentage = 100
view_percentage = 100

[bucket]
replica_number=0
replica_index=0
encryption_at_rest = true
dek_rotation_interval_secs = 7200
dek_lifetime_secs = 60
max_deks = 2

[collection]
config = collections/1bucket_1scope_1collection_basic.json

[load]
items = 18000000
size = 1024
workers = 100
doc_gen = hundred_index_doc
size_variation_min = 500
size_variation_max = 500

[secondary]
indexes = tests/gsi/index_defs/1bucket_1scope_1collection_100_indexes_plasma.json
cbindexperf_configfile = tests/gsi/plasma/config/config_scanlatency_sessionconsistent_100_indexes_1s_10c_partitioned.json
indexer.settings.storage_mode = plasma
indexer.settings.max_cpu_percent = 3600
indexer.settings.gc_percent = 200
queryport.client.usePlanner = false
queryport.client.log_level = Warn
projector.backChanSize = 500000
disable_perindex_stats = True
indexer.settings.build.batch_size = 100
cbindexperf_concurrency = 128
cbindexperf_repeat = 299999
dropkey_polling_interval_secs = 60
dropkey_test_duration_secs = 3600
dropkey_force_rotation = 1

[access]
updates = 100
ops = 50000000
items = 18000000
throughput = 10000
workers = 40
