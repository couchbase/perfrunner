# NOTE: The dataset (item count + doc size) and query shape below were
# tuned to force the query engine to spill its sort scratch data to
# disk on the iris cluster's specific hardware profile (CPU cores,
# memory). The spill thresholds derive from query engine formulas that
# depend on machine config, so if this test is ever moved to a
# different perf cluster the dataset and/or query MUST be re-derived
# against the new machine's spec — otherwise the workload may silently
# stop triggering spill and the pre-flight DEBUG probe will fail.

[test_case]
test = perfrunner.tests.n1ql.N1QLLatencySpillFileTest

[showfast]
title = Spill File, SELECT * ORDER BY email, Primary Index, Plasma, not_bounded, Native Encryption at Rest
component = n1ql
category = spill_file
sub_category = Plasma

[cluster]
mem_quota = 20480
index_mem_quota = 100000
initial_nodes = 6
num_buckets = 1

[compaction]
db_percentage = 100

[bucket]
replica_number = 0
encryption_at_rest = true
other_encryption_at_rest = true

[secondary]
indexer.settings.storage_mode = plasma

[load]
items = 1000000
size = 1024
workers = 80
doc_gen = reverse_lookup

[index]
statements =
    CREATE PRIMARY INDEX primary_idx ON `bucket-1`;

[access]
creates = 0
reads = 1
updates = 0
deletes = 0
items = 1000000
spring_batch_size = 1
workers = 1
throughput = 1
time = 3600
n1ql_queries = full-sort
n1ql_workers = 5
n1ql_batch_size = 1
n1ql_throughput = 1
n1ql_timeout = 3600

[n1ql-full-sort]
statement = SELECT * FROM `bucket-1` USE INDEX (primary_idx) ORDER BY email OFFSET 999999;
scan_consistency = not_bounded
args = []
