[test_case]
test = perfrunner.tests.tools.ContinuousBackupCDCOnlyTest

[showfast]
title = 4 nodes, 1 bucket x 100M x 1KB, 100%% Create, CDC only dry run, s=1, c=1
component = tools
category = continuous_backup

[cluster]
mem_quota = 52428
initial_nodes = 4
num_buckets = 1

[bucket]
replica_number = 1
backend_storage = magma
eviction_policy = fullEviction
history_seconds = 3600

[collection]
config = collections/1bucket_1scope_1collection_basic.json

[compaction]
bucket_compaction = false

[load]
items = 100000000
size = 1024
workers = 100

[access]
creates = 100
reads = 0
updates = 0
deletes = 0
items = 100000000
ops = 100000000
workers = 100
time = 86400
