[test_case]
test = perfrunner.tests.xdcr.BiDirXdcrInitTest

[showfast]
title = Avg. initial XDCR rate (items/sec), 2 <-> 2 (2 source nozzles, 4 target nozzles), 1 bucket x 100M x 1KB, Bidir, Non-optimistic replication, dcpFlowControlThrottle=5
component = xdcr
category = init_single
orderby = ba

[stats]
server_processes = goxdcr

[cluster]
mem_quota = 25000
initial_nodes = 2 2
num_buckets = 1

[bucket]
replica_number = 0

[xdcr_cluster]
sourceNozzlePerNode = 2
targetNozzlePerNode = 4
dcpFlowControlThrottle = 5

[load]
items = 100000000
size = 1024
workers = 80
doc_gen = large
conflict_ratio = 0
