[test_case]
test = perfrunner.tests.ycsb.YCSBN1QLThroughputTest

[showfast]
title = Avg Throughput (ops/sec), Airport Workload (default), 4 nodes
component = n1ql
category = ycsb
sub_category = Plasma

[cluster]
mem_quota = 40960
index_mem_quota = 40960
initial_nodes = 4
num_buckets = 1

[secondary]
indexer.settings.storage_mode = plasma

[load]
workload_path = workloads/workload_airport_default
ycsb_client = couchbase3
items = 20000000
workers = 40

[access]
workload_path = workloads/workload_airport_default
ycsb_client = couchbase3
items = 20000000
ops = 1000000000
time = 1200
workers = 600
workload_instances = 4
kv_endpoints = 1024

[ycsb]
branch = airport-release

[stats]
client_processes = java
