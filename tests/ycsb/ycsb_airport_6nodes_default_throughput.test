[test_case]
test = perfrunner.tests.ycsb.YCSBN1QLThroughputTest

[showfast]
title = Avg Throughput (ops/sec), Airport Workload (default), 6 nodes
component = n1ql
category = ycsb

[cluster]
mem_quota = 10240
index_mem_quota = 10240
initial_nodes = 6
num_buckets = 1
enable_cpu_cores = false

[bucket]
replica_number = 2
eviction_policy = fullEviction
backend_storage = couchstore

[secondary]
indexer.settings.storage_mode = plasma

[load]
workload_path = workloads/workload_airport_default
ycsb_client = couchbase3
items = 100_000_000
workers = 1000
workload_instances = 2
inserts_per_workerinstance = 50_000_000
phase = 1

[access]
workload_path = workloads/workload_airport_default
ycsb_client = couchbase3
items = 100_000_000
ops = 1000000000
time = 1200
workers = 600
workload_instances = 2
kv_endpoints = 1024

[ycsb]
branch = airport-release
latency_percentiles = 50,90,95,99

[stats]
client_processes = java
