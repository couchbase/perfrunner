[test_case]
test = perfrunner.tests.ycsb.YCSBN1QLLatencyCPUTest

[showfast]
title = Latency (ms), Workload E, Plasma, 6 nodes, 1 bucket x 20M x 1KB, 8 vCPU, 32 GB memory, 1K ops/sec
component = n1ql
category = ycsb
sub_category = Plasma

[cluster]
mem_quota = 20480
index_mem_quota = 4096
initial_nodes = 6
num_buckets = 1
online_cores = 4
kernel_mem_limit = 32G
kernel_mem_limit_services = kv

[bucket]
replica_number = 2

[secondary]
indexer.settings.storage_mode = plasma

[load]
workload_path = workloads/workloade
ycsb_client = couchbase3
items = 20000000
workers = 40

[index]
statements =
    CREATE PRIMARY INDEX primary_idx ON `bucket-1`;

[access]
workload_path = workloads/workloade
ycsb_client = couchbase3
items = 20000000
target = 1000
ops = 0
time = 600
workers = 60
workload_instances = 1
timeseries = 1
kv_endpoints = 512

[ycsb]
branch = couchbase3
latency_percentiles = 99
average_latency = 1

[stats]
client_processes = java